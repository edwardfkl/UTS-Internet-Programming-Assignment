APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Laravel & Carbon default; Australia/Sydney = NSW/VIC/ACT (AEDT/AEST).
APP_TIMEZONE=Australia/Sydney

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default: MySQL. Create the database first (e.g. CREATE DATABASE studio_supply;).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=studio_supply
DB_USERNAME=root
DB_PASSWORD=

# Optional: SQLite (comment out the MySQL block above). Then from backend/: touch database/database.sqlite
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Optional: frontend URL for links in emails, etc.
# FRONTEND_URL=http://localhost:3000

# SPA origins allowed to send cookies (admin web-session sync from Next.js). Use the exact origin you open the shop in (scheme + host + port).
# If you mix localhost and 127.0.0.1 in the browser, add both (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
